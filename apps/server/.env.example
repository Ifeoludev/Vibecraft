# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/vibecraft

# Server
PORT=3001
NODE_ENV=development
SERVER_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173

# JWT & Encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
ENCRYPTION_KEY=

# Google OAuth (app identity login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spotify OAuth (music export)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# 127.0.0.1 required — Spotify bans 'localhost' as a redirect URI
SPOTIFY_CALLBACK_URL=http://127.0.0.1:3001/api/auth/spotify/callback

# YouTube OAuth (music export — separate Google OAuth client with youtube.force-ssl scope)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Gemini AI
GEMINI_API_KEY=

# MusicAPI.com (public search — uses Client ID only, no secret needed)
MUSIC_API_KEY=
